# Firebase config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Redirect URL for the main CTA
VITE_TARGET_URL=

# Background — flat colour fallback
VITE_BG_COLOR=#ffb524
VITE_TEXT_COLOR=#ff003c

# Background image (name only, no extension) from public/images/
# Leave empty to use VITE_BG_COLOR instead
VITE_USE_BG=

# Logo image (name only, no extension) from public/images/
# Leave empty to use the bundled fallback asset
VITE_LOGO_IMAGE=
VITE_LOGO_WIDTH=400px

# Character / decorative image (name only, no extension) from public/images/
VITE_BUTTON_IMAGE=
VITE_BUTTON_WIDTH=300px

# Wishlist button image (name only, no extension) from public/images/
# Clicking redirects to VITE_TARGET_URL unless VITE_WISHLIST_URL is set
VITE_WISHLIST_IMAGE=
VITE_WISHLIST_WIDTH=400px

# Vimeo video ID (numbers only from the Vimeo URL)
# Leave empty to hide the video block
VITE_VIMEO_ID=

# Optional text shown below the button. Leave empty to hide.
VITE_TEXT_BLOCK=
